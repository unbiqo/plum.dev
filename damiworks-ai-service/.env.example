# ── Required ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Additional LLM providers (optional cross-provider fallback) ─────────────
# Used by profiles whose pools contain anthropic:/openai: entries
# (see MODEL_PROFILES in app/config.py). Empty = those pool entries are skipped.
# CLAUDE_API_KEY is accepted as an alias for ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Telegram lead notifications (optional) ──────────────────────────────────
# When empty the notifier no-ops (logs only) — backend still starts fine.
LEAD_TELEGRAM_BOT_TOKEN=
LEAD_TELEGRAM_CHAT_ID=

# ── Tuning (safe to leave at defaults) ──────────────────────────────────────
# MAX_HISTORY_MESSAGES=15
# RAG_MATCH_COUNT=3
# RAG_CHUNK_MAX_CHARS=1800
# RAG_CONTEXT_MAX_CHARS=5500
# SUMMARY_AFTER_MESSAGES=15
# ENABLE_B2B_MEMORY_SUMMARY=true
# INTELLIGENCE_SHADOW_ENABLED=true
# INSIGHT_EXTRACTOR_ENABLED=true
# ENABLE_GENERATION_FALLBACK=false
# LEAD_COST_BUDGET_USD=0.15
# EVAL_SAMPLE_RATE=0.17              # nightly quality_eval sample share (0.15-0.20)
# EVAL_ALERT_NATURALNESS_MIN=4.2     # alert threshold for the naturalness score
# EVAL_ALERT_OTHER_MIN=3.5           # alert threshold for the other rubric scores
