# URL of the running FastAPI backend (no trailing slash)
# Check the backend .env PORT= value — default is 8010 in local dev
FASTAPI_URL=http://localhost:8010

# Calendly booking link — primary conversion CTA (chat + contact section).
# Leave unset to hide all Calendly buttons; the contact form keeps working.
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/20min
